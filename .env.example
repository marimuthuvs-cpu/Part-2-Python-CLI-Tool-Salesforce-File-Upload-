# ──────────────────────────────────────────────────────────────────────────────
# Salesforce Authentication
#
# Option A — Client Credentials Flow (preferred for automation)
#   Requires a Connected App with Client Credentials Flow enabled.
#   See README.md for step-by-step Connected App setup instructions.
#
# Option B — Username-Password Flow (fallback)
#   Requires the same Connected App plus your Salesforce login credentials.
#   Security token is appended to the password automatically if provided.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required for both flows ────────────────────────────────────────────────
SF_CLIENT_ID=your_connected_app_consumer_key
SF_CLIENT_SECRET=your_connected_app_consumer_secret

# ── Additional fields for Username-Password flow (Option B) ───────────────
# SF_USERNAME=your_salesforce_username
# SF_PASSWORD=your_salesforce_password
# SF_SECURITY_TOKEN=your_security_token

# ──────────────────────────────────────────────────────────────────────────────
# Optional Overrides
# ──────────────────────────────────────────────────────────────────────────────
# SF_LOGIN_URL=https://login.salesforce.com
# SF_API_VERSION=65.0
